# Kill Bill
KB_HOST=killbill
KB_BASE=http://killbill:8080
KB_API_KEY=company_a
KB_API_SECRET=company_a_secret
KB_USERNAME=admin
KB_PASSWORD=password
KB_WEBHOOK_CALLBACK_URL=http://killbill-gateway:3005/api/webhooks/killbill
FLOWENGINE_URL=http://app:8000

# Payments
RAZORPAY_KEY_ID=replace-with-razorpay-key-id
RAZORPAY_KEY_SECRET=replace-with-razorpay-key-secret
STRIPE_SECRET_KEY=replace-with-stripe-secret-key

# Email
GMAIL_USER=your-smtp-user@example.com
GMAIL_APP_PASSWORD=replace-with-gmail-app-password
MAIL_FROM_NAME=AgentryX
MAIL_FROM_EMAIL=no-reply@example.com
TEST_EMAIL_TO=qa@example.com

# Optional Mautic integration
MAUTIC_URL=http://mautic:8080

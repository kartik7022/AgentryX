# App
APP_NAME=AgentryX
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development
COOKIE_DOMAIN=localhost

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/AgentryX

# JWT / Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_TTL_HOURS=8
PASSWORD_TOKEN_TTL_HOURS=24

# Frontend URLs
FRONTEND_BASE_URL=http://localhost:3000
ADMIN_HUB_URL=http://localhost:3000
ADMIN_UI_URL=http://localhost:5000
PORTAL_URL=http://localhost:3000

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-user@example.com
SMTP_PASSWORD=replace-with-smtp-app-password
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=AgentryX

# Vault
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=replace-with-vault-token
VAULT_KV_MOUNT=secret
VAULT_ROLE_ID=replace-with-vault-role-id
VAULT_SECRET_ID=replace-with-vault-secret-id
VAULT_AUTH_METHOD=token

# Credential Broker
BROKER_URL=http://localhost:9100
BROKER_TTL_SECONDS=600

# ODBC
MSSQL_ODBC_DRIVER=ODBC Driver 18 for SQL Server

# Super Admin
# Must be in email format.
SUPER_ADMIN_USERNAME=admin@example.com
SUPER_ADMIN_PASSWORD=replace-with-superadmin-password

# Google OAuth
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Keycloak
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=flowengine
KEYCLOAK_CLIENT_ID=agentryx-app
KEYCLOAK_CLIENT_SECRET=replace-with-keycloak-client-secret
KEYCLOAK_EXTERNAL_URL=http://localhost:7000
KEYCLOAK_INTERNAL_EXTERNAL_URL=http://host.docker.internal:7000
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=replace-with-keycloak-admin-password
KEYCLOAK_REDIRECT_URI=http://localhost:3000/auth/keycloak/callback

# Kill Bill Gateway
KILLBILL_GATEWAY_URL=http://killbill-gateway:3002
KILLBILL_API_KEY=company_a
KILLBILL_API_SECRET=company_a_secret

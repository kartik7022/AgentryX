{
  "_version": "1.59.0",
  "sap.app": {
    "id": "sapqueryapp",
    "type": "application",
    "title": "SAP Query App",
    "description": "SAP HANA Query Application",
    "applicationVersion": { "version": "1.0.0" },
    "dataSources": {}
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "rootView": {
      "viewName": "sapqueryapp.view.Main",
      "type": "XML",
      "id": "app"
    },
    "dependencies": {
      "minUI5Version": "1.98.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.f": {},
        "sap.ui.layout": {}
      }
    },
    "routing": {
      "routes": [
        {
          "name": "main",
          "pattern": "",
          "target": "main"
        }
      ],
      "targets": {
        "main": {
          "viewName": "Main",
          "viewLevel": 1
        }
      }
    }
  }

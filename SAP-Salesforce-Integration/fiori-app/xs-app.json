{
  "welcomeFile": "/index.html",
  "authenticationMethod": "none",
  "sessionTimeout": 30,
  "routes": [
    {
      "source": "^(.*)$",
      "target": "$1",
      "service": "html5-apps-repo-rt",
      "authenticationType": "none"
    }
  ],
  "responseHeaders": [
    {
      "name": "Content-Security-Policy",
      "value": "frame-ancestors 'self' https://*.salesforce.com https://*.force.com https://*.lightning.force.com"
    }
  ]
}
